# whatsmeow REST server — exemplo de configuração (copie para .env e ajuste)
# Estas variáveis são lidas do ambiente do processo (não há loader de .env embutido;
# no PowerShell use:  $env:PORT="8080"  antes de  go run ./restserver )

PORT=8080
# SQLite com WAL (durabilidade/concorrência). Em produção, troque por Postgres.
WHATSMEOW_DSN=file:whatsmeow.db?_pragma=foreign_keys(on)&_pragma=busy_timeout(5000)&_pragma=journal_mode(WAL)

# Watchdog de reconexão: intervalo em segundos (0 = desliga). Rede-de-segurança
# por cima do auto-reconnect do whatsmeow; reconecta instâncias pareadas que caíram.
WATCHDOG_SECONDS=30

# Histórico estruturado por instância: retenção máxima e intervalo de limpeza.
INSTANCE_LOG_RETENTION_DAYS=7
INSTANCE_LOG_CLEANUP_INTERVAL_MINUTES=60

# Auth global simples. Vazio = sem auth (conveniência local).
# Se setado, exija header  Authorization: Bearer <key>  (ou header  token: <key> )
ADMIN_API_KEY=

# Header x-uazapi-secret enviado nos webhooks de saída (formato uazapi)
WEBHOOK_SECRET=dev-secret

# Auto-resposta embutida para confirmação de consulta (digitar 1 ou 2)
AUTOREPLY_ENABLED=true
AUTOREPLY_CONFIRM_MSG=✅ Sua consulta foi confirmada! Até breve.
AUTOREPLY_CANCEL_MSG=❌ Sua consulta foi cancelada. Entre em contato para reagendar. 🗓️
